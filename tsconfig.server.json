{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-server",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["server/**/*", ".env"],
  "exclude": ["node_modules", "dist", "dist-server"]
}
